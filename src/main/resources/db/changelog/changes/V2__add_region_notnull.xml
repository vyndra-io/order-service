<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        BREAKING CHANGE — adds a NOT NULL column with no defaultValue.
        Liquibase cannot run this against a table that already has rows:
        existing rows cannot satisfy the NOT NULL constraint.
        Old versions of the app also cannot INSERT without supplying region.
        Contract Guardian should FAIL: rule not-null-added-no-default.

        Fix: either add a defaultValue (e.g. defaultValue="GLOBAL"),
        or add as nullable first, backfill, then add the NOT NULL constraint.
    -->
    <changeSet id="5" author="vyndra">
        <addColumn tableName="orders">
            <column name="region" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
